  "keyFeatures": [
    "Agent skill for Claude Code, Codex, opencode, Cline, and Cursor",
    "Self-contained native binary — no Node.js required",
    "Schedule posts across 32+ social media channels",
    "OAuth2 device-flow and API key authentication with persistent credentials",
    "Upload media before posting (required for images/video)",
    "Runtime integration settings discovery via `integrations:settings`",
    "JSON output for easy scripting and pipeline integration",
    "Covers agent-specific traps: strict JSON mode, media upload flow, thread chaining, draft behavior, and missing release IDs"
  ],
  "publicApiSurface": [
