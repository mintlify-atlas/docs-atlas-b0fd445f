    "groniz integrations trigger",
    "groniz posts create -c <content> -s <schedule> -i <integration-id>",
    "groniz posts list",
    "groniz posts delete <id>",
    "groniz posts missing <id>",
    "groniz posts connect",
    "groniz upload <file>",
